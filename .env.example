# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).

# --- LLM ---
GEMINI_API_KEY=your-gemini-api-key      # primary LLM (Gemini 2.5 Flash)
GROQ_API_KEY=your-groq-api-key          # LLM fallback + STT fallback + case extraction

# --- Speech ---
ELEVENLABS_API_KEY=your-elevenlabs-api-key   # Scribe STT + eleven_v3 TTS
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL     # optional TTS voice id
TTS_VOICE=bn-BD-NabanitaNeural               # edge-tts fallback voice

# --- Doctor dashboard auth (set a strong password in production) ---
DASHBOARD_USER=doctor
DASHBOARD_PASSWORD=change-this-password

# --- Conversation tuning (optional) ---
MAX_QA_TURNS=6
MAX_HISTORY=10

# --- Server (the host platform usually sets PORT automatically) ---
# PORT=8000
# HOST=0.0.0.0
