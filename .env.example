# ─── LLM Provider ────────────────────────────────────────────────────────────
# Options: "ollama" | "openai" | "anthropic"
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=aya-expanse:8b

# Cloud API keys (used when LLM_PROVIDER=openai or anthropic)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── STT Provider ────────────────────────────────────────────────────────────
# Options: "openai" | "groq" | "mlx"
# - openai: Uses OpenAI Whisper API (requires OPENAI_API_KEY)
# - groq:   Uses Groq Whisper API — fast, generous free tier (requires GROQ_API_KEY)
# - mlx:    Local Apple Silicon Whisper (install mlx-whisper, no API key needed)
STT_PROVIDER=openai

GROQ_API_KEY=

# mlx-whisper model size: tiny / base / small / medium / large-v3
MLX_WHISPER_MODEL=base

# ─── TTS Provider ────────────────────────────────────────────────────────────
# Options: "edge-tts" | "gtts"
# edge-tts: Microsoft neural Bangla voice (best quality, requires internet)
# gtts:     Google TTS (fallback, requires internet)
TTS_PROVIDER=edge-tts

# edge-tts voice for Bangla
# Female: bn-BD-NabanitaNeural | Male: bn-BD-PradeepNeural
TTS_VOICE=bn-BD-NabanitaNeural

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8000
